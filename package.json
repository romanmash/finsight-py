{
  "name": "finsight-ai-hub",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "check:secrets": "node scripts/check-no-hardcoded-secrets.mjs",
    "mcp:typecheck": "pnpm --filter @finsight/mcp-servers typecheck",
    "mcp:lint": "pnpm --filter @finsight/mcp-servers lint",
    "mcp:test": "pnpm --filter @finsight/mcp-servers test",
    "mcp:dev:market-data": "pnpm --filter @finsight/mcp-servers dev:market-data",
    "mcp:dev:macro-signals": "pnpm --filter @finsight/mcp-servers dev:macro-signals",
    "mcp:dev:news": "pnpm --filter @finsight/mcp-servers dev:news",
    "mcp:dev:rag-retrieval": "pnpm --filter @finsight/mcp-servers dev:rag-retrieval",
    "mcp:dev:enterprise-connector": "pnpm --filter @finsight/mcp-servers dev:enterprise-connector",
    "mcp:dev:trader-platform": "pnpm --filter @finsight/mcp-servers dev:trader-platform",
    "telegram:typecheck": "pnpm --filter @finsight/telegram-bot typecheck",
    "telegram:test": "pnpm --filter @finsight/telegram-bot test",
    "telegram:dev": "pnpm --filter @finsight/telegram-bot dev",
    "dashboard:typecheck": "pnpm --filter @finsight/dashboard typecheck",
    "dashboard:test": "pnpm --filter @finsight/dashboard test",
    "dashboard:dev": "pnpm --filter @finsight/dashboard dev",
    "dashboard:build": "pnpm --filter @finsight/dashboard build",
    "seed:test": "vitest run prisma/__tests__ --pool=threads",
    "validate:011:parity": "node tools/validation/check-011-parity.mjs",
    "deploy:remote": "bash scripts/deploy.sh",
    "seed:run": "pnpm prisma db seed",
    "validate:011:pulumi": "node tools/validation/validate-pulumi-preview.mjs",
    "logs:remote": "bash scripts/logs.sh",
    "validate:011:ci": "node tools/validation/validate-ci-cd-policy.mjs",
    "validate:011:env": "node tools/validation/validate-env-contract.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prisma": "^6.19.2",
    "typescript": "~5.8.0",
    "vitest": "^3.1.0",
    "zod": "^3.24.0",
    "tsx": "^4.19.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
