{
  "mcpServers": {
    "debug-infra": {
      "type": "http",
      "url": "http://localhost:8010/mcp/"
    },
    "debug-browser": {
      "command": "bash",
      "args": [
        "scripts/docker-auto.sh",
        "run", "-i", "--rm",
        "--network", "finsight_default",
        "-e", "E2E_DASHBOARD_URL=http://dashboard:8050",
        "mcp/playwright"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Bash(uv sync*)",
      "Bash(uv run mypy --strict)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff check*)",
      "Bash(uv run alembic upgrade head)",
      "Bash(uv run python -m scripts.seed)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(docker compose config)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(npx -y*)"
    ]
  }
}
