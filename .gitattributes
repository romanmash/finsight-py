# Normalize line endings to LF on checkout
* text=auto eol=lf

# Force LF for project text files
*.py text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.toml text eol=lf
*.sql text eol=lf

# Shell scripts must be LF (critical for Docker builds)
*.sh text eol=lf
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
