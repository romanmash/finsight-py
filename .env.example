# Database
DATABASE_URL="postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>"
REDIS_URL="redis://<redis_host>:6379"

# MCP provider credentials
FINNHUB_API_KEY="<finnhub_api_key>"
FMP_API_KEY="<fmp_api_key>"
ALPHA_VANTAGE_API_KEY="<alpha_vantage_api_key>"

# MCP mock modes
MCP_ENTERPRISE_CONNECTOR_MODE="mock"
MCP_TRADER_PLATFORM_MODE="mock"

# Dashboard (Feature 010)
VITE_DAILY_BUDGET_USD=25
VITE_API_BASE_URL=http://localhost:3000

# Seed (Feature 011)
ADMIN_EMAIL="admin@finsight.local"            # Required seed admin identity
ADMIN_PASSWORD="<admin_password>"             # Required seed admin password (secret placeholder)
ANALYST_EMAIL="analyst@finsight.local"        # Optional override for seeded analyst identity
ANALYST_PASSWORD="<analyst_password>"         # Optional override for seeded analyst password
SEED_PROFILE="demo-default"                   # Seed profile name/version selector

# CI/CD and deployment automation (Feature 011)
DEPLOY_HOST="<deploy_host>"                   # Required in deploy-capable CI and scripts/deploy.sh
DEPLOY_USER="<deploy_user>"                   # Required in deploy-capable CI and scripts/deploy.sh
DEPLOY_PATH="/opt/finsight"                   # Remote app path for artifact sync and compose actions
COMPOSE_PROJECT_NAME="finsight"               # Compose project name used by deploy scripts
HEALTHCHECK_URLS="http://localhost:3000/health"  # Comma-separated post-deploy health endpoints
PULUMI_STACK="dev"                            # Pulumi stack target used for preview/provision
PULUMI_CONFIG_PASSPHRASE="<pulumi_passphrase>"   # Required for encrypted Pulumi config backends
