# Core runtime settings
DATABASE_URL="postgresql+asyncpg://<db_user>:<db_password>@<db_host>:5432/<db_name>"
REDIS_URL="redis://<redis_host>:6379/0"
OPENAI_API_KEY="<openai_api_key>"
ANTHROPIC_API_KEY="<anthropic_api_key>"          # Optional
FINNHUB_API_KEY="<finnhub_api_key>"              # Optional
TELEGRAM_BOT_TOKEN="<telegram_bot_token>"        # Optional
TELEGRAM_SERVICE_TOKEN="<telegram_service_token>"  # Generated by Feature 011 seed script; copy from seed output
SECRET_KEY="<strong_secret_key>"
ENVIRONMENT="dev"
LOG_LEVEL="INFO"
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY="<langchain_api_key>"          # Optional

# Additional local/deployment configuration
FMP_API_KEY="<fmp_api_key>"
ALPHA_VANTAGE_API_KEY="<alpha_vantage_api_key>"
MCP_ENTERPRISE_CONNECTOR_MODE="mock"
MCP_TRADER_PLATFORM_MODE="mock"
VITE_DAILY_BUDGET_USD=25
VITE_API_BASE_URL=http://localhost:8000
ADMIN_EMAIL="admin@finsight.local"
ADMIN_PASSWORD="<admin_password>"
ANALYST_EMAIL="analyst@finsight.local"
ANALYST_PASSWORD="<analyst_password>"
SEED_PROFILE="demo-default"
DEPLOY_HOST="<deploy_host>"
DEPLOY_USER="<deploy_user>"
DEPLOY_PATH="/opt/finsight"
COMPOSE_PROJECT_NAME="finsight"
HEALTHCHECK_URLS="http://localhost:8000/health"
PULUMI_STACK="dev"
PULUMI_CONFIG_PASSPHRASE="<pulumi_passphrase>"
